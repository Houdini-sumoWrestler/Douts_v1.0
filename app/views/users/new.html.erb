<div class="login-container">
  <div class="login-card">

    <h1>Join DOUTS</h1>

    <% if flash[:alert] %>
      <div class="flash-alert"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: register_path,
                  method: :post,
                  local: true,
                  id: "register-form",
                  data: {
                    controller: "registration",
                    action: "submit->registration#validate"
                  } do %>

      <div class="form-group">
        <%= label_tag :first_name, "First name" %>
        <%= text_field_tag :first_name, nil,
            id: "first-name",
            class: "form-input",
            data: { registration_target: "firstName" } %>
      </div>

      <div class="form-group">
        <%= label_tag :last_name, "Last name" %>
        <%= text_field_tag :last_name, nil,
            id: "last-name",
            class: "form-input",
            data: { registration_target: "lastName" } %>
      </div>

      <div class="form-group">
        <%= label_tag :email, "Email" %>
        <%= email_field_tag :email, nil,
            id: "email",
            class: "form-input",
            data: { registration_target: "email" } %>
      </div>

      <div class="form-group">
        <%= label_tag :password, "Password" %>
        <%= password_field_tag :password, nil,
            id: "password",
            class: "form-input",
            data: { registration_target: "password" } %>
      </div>

      <div class="form-group">
        <%= label_tag :password_confirmation, "Confirm password" %>
        <%= password_field_tag :password_confirmation, nil,
            id: "password-confirmation",
            class: "form-input",
            data: { registration_target: "passwordConfirmation" } %>
      </div>

      <div class="form-group">
        <%= label_tag :membership_class, "Membership type" %>
        <%= select_tag :membership_class,
            options_for_select([
                ["Student - $20", "student"],
                ["Alumni - $20", "alumni"],
                ["Wider Community Member - $50", "wider_community"]
            ]),
            prompt: "Select membership type",
            class: "form-input",
            data: { registration_target: "membershipClass" } %>
        </div>

        <div class="form-group terms-checkbox">
        <%= check_box_tag :code_of_conduct_accepted, "1", false,
            data: { registration_target: "codeOfConduct" } %>
        <%= label_tag :code_of_conduct_accepted, "I agree to follow the DOUTS Code of Conduct" %>
        </div>

        <div class="form-group terms-checkbox">
        <%= check_box_tag :terms_accepted, "1", false,
            data: { registration_target: "terms" } %>
        <%= label_tag :terms_accepted, "I agree to the DOUTS terms and conditions" %>
        </div>

      <p id="register-error" class="flash-alert" data-registration-target="error"></p>

      <%= submit_tag "Join DOUTS", class: "login-button" %>
    <% end %>

  </div>
</div>