<h1>Join DOUTS</h1>

<% if flash[:alert] %>
  <p><%= flash[:alert] %></p>
<% end %>

<%= form_with url: register_path, method: :post, local: true, id: "register-form" do %>
  <div>
    <%= label_tag :first_name, "First name" %><br>
    <%= text_field_tag :first_name, nil, id: "first-name" %>
  </div>

  <br>

  <div>
    <%= label_tag :last_name, "Last name" %><br>
    <%= text_field_tag :last_name, nil, id: "last-name" %>
  </div>

  <br>

  <div>
    <%= label_tag :email, "Email" %><br>
    <%= email_field_tag :email, nil, id: "email" %>
  </div>

  <br>

  <div>
    <%= label_tag :password, "Password" %><br>
    <%= password_field_tag :password, nil, id: "password" %>
  </div>

  <br>

  <p id="register-error"></p>

  <%= submit_tag "Join DOUTS" %>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("register-form");
    const firstName = document.getElementById("first-name");
    const lastName = document.getElementById("last-name");
    const email = document.getElementById("email");
    const password = document.getElementById("password");
    const error = document.getElementById("register-error");

    form.addEventListener("submit", function (event) {
      error.textContent = "";

      if (
        firstName.value.trim() === "" ||
        lastName.value.trim() === "" ||
        email.value.trim() === "" ||
        password.value.trim() === ""
      ) {
        event.preventDefault();
        error.textContent = "Please complete all fields.";
      }
    });
  });
</script>