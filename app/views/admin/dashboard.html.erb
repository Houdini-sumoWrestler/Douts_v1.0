<div class="dashboard-container">

  <div class="dashboard-card">
    <h1>DOUTS Admin Dashboard</h1>

    <p>God mode activated.</p>

    <p>You are logged in as an admin.</p>
  </div>

  <div class="dashboard-grid">

    <%= link_to pages_path, class: "dashboard-button-card" do %>
      <h2>Website Pages</h2>
      <p>Manage website content and pages.</p>
    <% end %>

    <%= link_to events_path, class: "dashboard-button-card" do %>
      <h2>Events</h2>
      <p>Create and manage club events.</p>
    <% end %>

    <%= link_to assets_path, class: "dashboard-button-card" do %>
      <h2>Assets</h2>
      <p>Manage club equipment and bookings.</p>
    <% end %>

    <div class="dashboard-button-card disabled-card">
      <h2>Members</h2>
      <p>Coming soon.</p>
    </div>

    <div class="dashboard-button-card disabled-card">
      <h2>Payments</h2>
      <p>Coming soon.</p>
    </div>

    <div class="dashboard-button-card disabled-card">
      <h2>Email</h2>
      <p>Coming soon.</p>
    </div>

  </div>

  <p>
    <%= link_to "Back to Home", root_path, class: "dashboard-back-link" %>
  </p>

</div>