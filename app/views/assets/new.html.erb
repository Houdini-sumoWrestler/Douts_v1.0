<h1>Add Asset</h1>

<% if @asset.errors.any? %>
  <div>
    <h3>Please fix the following:</h3>

    <ul>
      <% @asset.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @asset, local: true do |form| %>
  <div>
    <%= form.label :name %><br>
    <%= form.text_field :name %>
  </div>

  <br>

  <div>
    <%= form.label :category %><br>
    <%= form.text_field :category %>
  </div>

  <br>

  <div>
    <%= form.label :quantity %><br>
    <%= form.number_field :quantity, min: 0 %>
  </div>

  <br>

  <div>
    <%= form.label :description %><br>
    <%= form.text_area :description, rows: 5 %>
  </div>

  <br>

  <%= form.submit "Create Asset" %>
<% end %>

<br>

<p>
  <%= link_to "Back to Assets", assets_path %>
</p>