<div class="dashboard-page">

  <section class="dashboard-profile-card">
    <div class="profile-avatar">
      <span>👤</span>
    </div>

    <h2><%= current_user.email.split("@").first.titleize %></h2>

    <p><strong>Email:</strong><br><%= current_user.email %></p>
    <p><strong>Role:</strong><br><%= current_user.role.titleize %></p>

    <%= link_to "Edit Profile +", "#", class: "primary-button" %>
  </section>

  <section class="dashboard-menu-area">

    <h1>DOUTS Admin Dashboard</h1>

    <div class="dashboard-menu-grid">

      <div class="dashboard-menu-card">
        <h2>Website Management</h2>

        <%= link_to "View Navigation", nav_items_path %>
        <%= link_to "Edit Navigation", edit_menu_nav_items_path %>
      </div>

      <div class="dashboard-menu-card">
        <h2>Events</h2>

        <%= link_to "View Events", events_path %>
        <%= link_to "Create Event", new_event_path %>
      </div>

      <div class="dashboard-menu-card">
        <h2>Assets</h2>

        <%= link_to "Asset Register", assets_path %>
        <%= link_to "Add Asset", new_asset_path %>
      </div>

      <div class="dashboard-menu-card">
        <h2>Membership</h2>

        <%= link_to "Members", "#" %>
        <%= link_to "Payments", "#" %>
        <%= link_to "Certifications", "#" %>
      </div>

      <div class="dashboard-menu-card">
        <h2>Club Admin</h2>

        <%= link_to "Documents", "#" %>
        <%= link_to "Meetings", "#" %>
        <%= link_to "Email Members", "#" %>
      </div>

      <div class="dashboard-menu-card">
        <h2>My Account</h2>

        <%= link_to "My Profile", "#" %>
        <%= link_to "My Events", "#" %>
        <%= link_to "Log Out", logout_path, data: { turbo_method: :delete } %>
      </div>

    </div>

  </section>

</div>