<div class="dashboard-container">
  <div class="user-dashboard-card">
    <h1>DOUTS Dashboard</h1>

    <p class="dashboard-intro">Welcome to your dashboard.</p>

    <section class="dashboard-section">
      <h2>Your Account</h2>

      <p><strong>Email:</strong> <%= @user.email %></p>
      <p><strong>Role:</strong> <%= @user.role %></p>
    </section>

    <section class="dashboard-section">
      <h2>Your Member Details</h2>

      <% if @member %>
        <p><strong>Name:</strong> <%= @member.first_name %> <%= @member.last_name %></p>
        <p><strong>Phone:</strong> <%= @member.phone || "Not provided yet" %></p>
        <p><strong>Membership expiry:</strong> <%= @member.membership_expiry_date || "Not set yet" %></p>
      <% else %>
        <p>No member profile found.</p>
      <% end %>
    </section>

    <section class="dashboard-section">
      <h2>Member Tools</h2>

      <div class="dashboard-actions">
        <%= link_to "View events", "#", class: "dashboard-button" %>
        <%= link_to "Update my details", "#", class: "dashboard-button" %>
      </div>
    </section>

    <% if @user.admin? %>
      <section class="dashboard-section">
        <h2>Admin Tools</h2>

        <div class="dashboard-actions">
          <%= link_to "Admin Dashboard", admin_path, class: "dashboard-button admin-button" %>
          <%= link_to "Manage members", "#", class: "dashboard-button admin-button" %>
          <%= link_to "Manage events", "#", class: "dashboard-button admin-button" %>
          <%= link_to "Manage payments", "#", class: "dashboard-button admin-button" %>
          
        </div>
      </section>

      <%= link_to nav_items_path, class: "dashboard-button-card" do %>
        <h2>Navigation</h2>
        <p>Edit the main menu and dropdown links.</p>
        <% end %>
    <% end %>

    <%= link_to "Back to Home", root_path, class: "back-link" %>
  </div>
</div>