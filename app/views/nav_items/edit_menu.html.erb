<div class="dashboard-container">
  <div class="user-dashboard-card">
    <h1>Edit Site Navigation</h1>

    <p class="dashboard-intro">
      Add, hide, rename, reorder, or delete navigation items.
    </p>

    <%= form_with url: save_menu_nav_items_path,
                  method: :patch,
                  local: true,
                  data: { controller: "nav-reorder" } do %>

      <div class="nav-toolbar">
        <button type="button"
                class="primary-button"
                data-action="click->nav-reorder#addTopLevel">
          Add Menu Item
        </button>
      </div>

      <%= render "menu_editor", nav_items: @nav_items %>

      <div class="nav-toolbar">
        <%= submit_tag "Save Changes", class: "primary-button" %>

        <%= link_to "Cancel",
            nav_items_path,
            class: "secondary-button" %>
      </div>
    <% end %>
  </div>
</div>