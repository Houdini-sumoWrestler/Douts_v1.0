<% child ||= false %>
<% moved_item_id ||= nil %>
<% moved = nav_item.id == moved_item_id %>

<%= turbo_frame_tag dom_id(nav_item) do %>
  <div class="<%= child ? 'nav-child-row' : 'nav-parent-row' %> <%= 'nav-just-moved' if moved %>"
       data-nav-item-id="<%= nav_item.id %>">

    <div class="nav-info">
      <% if child %>
        <h4><%= nav_item.title %></h4>
      <% else %>
        <h3><%= nav_item.title %></h3>
      <% end %>
    </div>

    <div class="nav-actions">
      <%= button_to "↑",
          move_up_nav_item_path(nav_item),
          method: :patch,
          class: "reorder-button" %>

      <%= button_to "↓",
          move_down_nav_item_path(nav_item),
          method: :patch,
          class: "reorder-button" %>

      <%= link_to "Edit",
          edit_nav_item_path(nav_item),
          class: "warning-button",
          data: { turbo_frame: dom_id(nav_item) } %>

      <%= link_to "Delete",
          nav_item_path(nav_item),
          class: "danger-button",
          data: {
            turbo_method: :delete,
            turbo_confirm: "Delete this navigation item?"
          } %>
    </div>
  </div>
<% end %>