<!DOCTYPE html>
<html>
  <head>
    <title>DOUTS Portal</title>

    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
  <header>
    <div class="top-strip">
      <div class="social-links">
        <span>f</span>
        <span>◎</span>
      </div>

      <div class="login-link">
        <a href="#">↪ Log in</a>
      </div>
    </div>

    <nav class="main-nav">
      <div class="logo-box">
        <%= image_tag "douts_logo.png", alt: "DOUTS Logo", class: "site-logo" %>
      </div>

      <div class="nav-links">
        <a href="/">Home</a>
        <a href="#">About</a>
        <a href="#">Diver Training</a>
        <a href="#">Events Calendar</a>
        <a href="#">Membership</a>
        <a href="#">Governance</a>
        <a href="#">Members Area</a>
        <a href="#">Contact Us</a>
      </div>
    </nav>
  </header>

  <main>
    <%= yield %>
  </main>

  <footer class="site-footer">
    <p>© <%= Time.now.year %> DOUTS</p>
  </footer>
</body>
</html>