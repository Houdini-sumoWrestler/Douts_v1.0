<!DOCTYPE html>
<html>
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>DOUTS Portal</title>

    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% current_user = User.find_by(id: session[:user_id]) %>

    <header class="site-header">
      <div class="top-strip">
        <div class="social-links">
          <span>f</span>
          <span>◎</span>
        </div>

        <div class="login-link">
          <% if current_user %>
            <%= link_to "Dashboard", dashboard_path %>
            |
            <%= button_to "Log out", logout_path, method: :delete, form: { style: "display:inline;" } %>
          <% else %>
            <%= link_to "↪ Log in", login_path %>
          <% end %>
        </div>
      </div>

      <nav class="main-nav">
        <div class="nav-inner">
          <div class="logo-box">
            <%= link_to root_path do %>
              <%= image_tag "douts_logo.png", class: "site-logo" %>
            <% end %>
          </div>

    <div class="nav-links">

        <div class="nav-links">
          <%= link_to "Home", root_path %>

          <div class="dropdown">
            <a href="#">About ▾</a>
            <div class="dropdown-menu">
              <%= link_to "About DOUTS", "#" %>
              <%= link_to "Committee", "#" %>
              <%= link_to "FAQs", "#" %>
              <%= link_to "Club Documents", "#" %>
              <%= link_to "Contact Us", "#" %>
            </div>
          </div>

          <div class="dropdown">
            <a href="#">Learn to Dive ▾</a>
            <div class="dropdown-menu">
              <%= link_to "Learn to Dive", "#" %>
              <%= link_to "SSI Courses", "#" %>
              <%= link_to "Open Water", "#" %>
              <%= link_to "Advanced Courses", "#" %>
            </div>
          </div>

          <div class="dropdown">
            <%= link_to "Events ▾", events_path %>
            <div class="dropdown-menu">
              <%= link_to "Events Calendar", events_path %>
              <%= link_to "Upcoming Events", events_path %>
            </div>
          </div>

          <div class="dropdown">
            <a href="#">Membership ▾</a>
            <div class="dropdown-menu">
              <%= link_to "Join DOUTS", register_path %>
              <%= link_to "Membership Information", "#" %>
              <%= link_to "Equipment Hire", assets_path %>
            </div>
          </div>

          <% if current_user %>
            <div class="dropdown">
              <%= link_to "Members ▾", dashboard_path %>
              <div class="dropdown-menu">
                <%= link_to "Dashboard", dashboard_path %>
                <%= link_to "My Events", "#" %>
                <%= link_to "My Equipment Bookings", "#" %>
                <%= link_to "My Profile", "#" %>
              </div>
            </div>
          <% end %>

          <% if current_user&.admin? %>
            <div class="dropdown">
              <%= link_to "Admin ▾", admin_path %>
              <div class="dropdown-menu">
                <%= link_to "Admin Dashboard", admin_path %>
                <%= link_to "Manage Events", events_path %>
                <%= link_to "Manage Assets", assets_path %>
                <%= link_to "Add Asset", new_asset_path %>
              </div>
            </div>
          <% end %>
        </div>
      </nav>
    </header>

    <% if flash[:notice] %>
      <p><%= flash[:notice] %></p>
    <% end %>

    <% if flash[:alert] %>
      <p><%= flash[:alert] %></p>
    <% end %>

    <main class="page-content">
      <%= yield %>
    </main>

    <footer class="site-footer">
      <p>© <%= Time.now.year %> DOUTS</p>
    </footer>
  </body>
</html>