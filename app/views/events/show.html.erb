<h1><%= @event.title %></h1>

<p>
  <strong>Description:</strong><br>
  <%= @event.description %>
</p>

<p>
  <strong>Start:</strong>
  <%= @event.start_datetime %>
</p>

<p>
  <strong>End:</strong>
  <%= @event.end_datetime %>
</p>

<p>
  <strong>Meeting Point:</strong>
  <%= @event.meeting_point %>
</p>

<p>
  <strong>Location:</strong>
  <%= @event.location %>
</p>

<p>
  <strong>Capacity:</strong>
  <%= @event.capacity %>
</p>

<h2>Registration</h2>

<% if session[:user_id] %>
  <% current_user = User.find_by(id: session[:user_id]) %>
  <% current_member = current_user&.member %>

  <% if current_member %>
    <% registration = @event.event_registrations.find_by(member: current_member) %>

    <% if registration %>
      <p>You are registered for this event.</p>

      <%= button_to "Cancel Registration",
          event_registration_path(registration),
          method: :delete %>
    <% else %>
      <%= button_to "Register for Event",
          event_event_registrations_path(@event),
          method: :post %>
    <% end %>
  <% else %>
    <p>You need a member profile before registering.</p>
  <% end %>
<% else %>
  <p>
    <%= link_to "Login to register", login_path %>
  </p>
<% end %>

<h2>Assets Available for This Event</h2>

<% if @event.event_assets.any? %>
  <table border="1">
    <thead>
      <tr>
        <th>Asset</th>
        <th>Quantity Available</th>
        <th>Price</th>
        <% if User.find_by(id: session[:user_id])&.admin? %>
          <th>Action</th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% @event.event_assets.each do |event_asset| %>
        <tr>
          <td><%= event_asset.asset.name %></td>
          <td><%= event_asset.quantity_available %></td>
          <td>
            <% if event_asset.price.present? %>
              $<%= event_asset.price %>
            <% else %>
              Free
            <% end %>
          </td>

          <% if User.find_by(id: session[:user_id])&.admin? %>
            <td>
              <%= button_to "Remove",
                  event_asset_path(event_asset),
                  method: :delete %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No assets have been added to this event yet.</p>
<% end %>

<% current_user = User.find_by(id: session[:user_id]) %>

<% if current_user&.admin? %>
  <h3>Add Asset to Event</h3>

  <%= form_with url: event_event_assets_path(@event), method: :post, local: true do %>
    <div>
      <%= label_tag :asset_id, "Asset" %><br>
      <%= select_tag :asset_id,
          options_from_collection_for_select(Asset.order(:name), :id, :name) %>
    </div>

    <br>

    <div>
      <%= label_tag :quantity_available, "Quantity available for this event" %><br>
      <%= number_field_tag :quantity_available, nil, min: 0 %>
    </div>

    <br>

    <div>
      <%= label_tag :price, "Price for this event" %><br>
      <%= number_field_tag :price, nil, min: 0, step: 0.01 %>
    </div>

    <br>

    <%= submit_tag "Add Asset" %>
  <% end %>
<% end %>

<p>
  <%= link_to "Back to Events", events_path %>
</p>