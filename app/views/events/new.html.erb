<h1>Create Event</h1>

<% if @event.errors.any? %>
  <div>
    <h3>Please fix the following:</h3>

    <ul>
      <% @event.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @event, local: true do |form| %>

  <div>
    <%= form.label :title %><br>
    <%= form.text_field :title %>
  </div>

  <br>

  <div>
    <%= form.label :description %><br>
    <%= form.text_area :description, rows: 6 %>
  </div>

  <br>

  <div>
    <%= form.label :start_datetime, "Start Date & Time" %><br>
    <%= form.datetime_local_field :start_datetime %>
  </div>

  <br>

  <div>
    <%= form.label :end_datetime, "End Date & Time" %><br>
    <%= form.datetime_local_field :end_datetime %>
  </div>

  <br>

  <div>
    <%= form.label :meeting_point %><br>
    <%= form.text_field :meeting_point %>
  </div>

  <br>

  <div>
    <%= form.label :location %><br>
    <%= form.text_field :location %>
  </div>

  <br>

  <div>
    <%= form.label :capacity %><br>
    <%= form.number_field :capacity, min: 1 %>
  </div>

  <br>

  <%= form.submit "Create Event" %>

<% end %>

<br>

<p>
  <%= link_to "Back to Events", events_path %>
</p>