<h1>DOUTS Login</h1>

<% if flash[:alert] %>
  <p><%= flash[:alert] %></p>
<% end %>

<% if flash[:notice] %>
  <p><%= flash[:notice] %></p>
<% end %>

<%= form_with url: login_path, method: :post, local: true, id: "login-form" do %>
  <div>
    <%= label_tag :email, "Email" %><br>
    <%= email_field_tag :email, nil, id: "email" %>
  </div>

  <br>

  <div>
    <%= label_tag :password, "Password" %><br>
    <%= password_field_tag :password, nil, id: "password" %>
  </div>

  <br>

  <div>
    <input type="checkbox" id="show-password">
    <label for="show-password">Show password</label>
  </div>

  <br>

  <p id="login-error"></p>

  <%= submit_tag "Login" %>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("login-form");
    const email = document.getElementById("email");
    const password = document.getElementById("password");
    const error = document.getElementById("login-error");
    const showPassword = document.getElementById("show-password");

    showPassword.addEventListener("change", function () {
      password.type = this.checked ? "text" : "password";
    });

    form.addEventListener("submit", function (event) {
      error.textContent = "";

      if (email.value.trim() === "" || password.value.trim() === "") {
        event.preventDefault();
        error.textContent = "Please enter both email and password.";
      }
    });
  });
</script>