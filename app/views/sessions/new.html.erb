<div class="login-container">
  <div class="login-card">

    <h1>DOUTS Login</h1>

    <% if flash[:alert] %>
      <div class="flash-alert"><%= flash[:alert] %></div>
    <% end %>

    <% if flash[:notice] %>
      <div class="flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <%= form_with url: login_path,
                  method: :post,
                  local: true,
                  id: "login-form",
                  data: {
                    controller: "login",
                    action: "submit->login#validate"
                  } do %>

      <div class="form-group">
        <%= label_tag :email, "Email" %>
        <%= email_field_tag :email, nil,
              id: "email",
              class: "form-input",
              data: { login_target: "email" } %>
      </div>

      <div class="form-group">
        <%= label_tag :password, "Password" %>
        <%= password_field_tag :password, nil,
              id: "password",
              class: "form-input",
              data: { login_target: "password" } %>
      </div>

      <div class="show-password">
        <input type="checkbox"
               id="show-password"
               data-action="change->login#togglePassword">

        <label for="show-password">Show password</label>
      </div>

      <p id="login-error" data-login-target="error"></p>

      <%= submit_tag "Login", class: "login-button" %>

    <% end %>

  </div>
</div>